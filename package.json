{
  "name": "country-flags-krishnarao",
  "version": "0.1.0",
  "description": "A lightweight library for displaying country flags",
  "main": "./dist/country-flags-lib.umd.cjs",
  "module": "./dist/country-flags-lib.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/country-flags-lib.js",
      "require": "./dist/country-flags-lib.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --emitDeclarationOnly && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "country",
    "flags",
    "react",
    "library",
    "typescript"
  ],
  "author": "Krishnarao",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.4"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0"
  }
}
